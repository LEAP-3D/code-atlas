# Go to root
cd ~/Desktop/shideeguibna

# Create .gitignore if it doesn't exist
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
*/node_modules/
back-end/node_modules/
front-end/node_modules/

# Environment variables
.env
*/.env
back-end/.env

# Build outputs
dist/
out/
*/dist/
*/out/

# VS Code
.vscode/
*.vsix

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
EOF