{
  "name": "codeatlas-saruul",
  "displayName": "Code-Atlas",
  "description": "Visualize call graphs and code structure through diagram",
  "version": "0.0.1",
  "publisher": "saruul",
  "repository": {
    "type": "git",
    "url": "https://github.com/LEAP-3D/shideeguibna"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:codeTree",
    "onView:userWebview",
    "onCommand:experiment.showSelectedCode",
    "onCommand:experiment.showRoadmap"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "experimentSidebar",
          "title": "Experiment",
          "icon": "media/roadmap.svg"
        }
      ]
    },
    "views": {
      "experimentSidebar": [
        {
          "id": "aiProviderView",
          "name": "AI Provider",
          "type": "webview"
        },
        {
          "id": "codeTree",
          "name": "Selected Code"
        },
        {
          "id": "userWebview",
          "name": "User",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "experiment.showSelectedCode",
        "title": "Show Selected Code"
      },
      {
        "command": "experiment.showRoadmap",
        "title": "Show Project Roadmap"
      },
      {
        "command": "experiment.askAI",
        "title": "Ask AI (with context)"
      }
    ],
    "keybindings": [
      {
        "command": "experiment.showSelectedCode",
        "key": "ctrl+alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "experiment.askAI",
        "key": "ctrl+alt+a",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build": "tsc -p ./"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@google/generative-ai": "^0.24.1",
    "groq-sdk": "^0.37.0",
    "openai": "^6.17.0"
  }
}
