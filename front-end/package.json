{
  "name": "codeatlas-saruul",
  "displayName": "Code-Atlas",
  "description": "Visualize call graphs and code structure through diagram",
  "icon": "media/Group.png",
  "version": "0.1.0",
  "publisher": "saruul",
  "repository": {
    "type": "git",
    "url": "https://github.com/LEAP-3D/shideeguibna"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "experimentSidebar",
          "title": "Experiment",
          "icon": "media/Group.png"
        }
      ]
    },
    "views": {
      "experimentSidebar": [
        {
          "id": "codeTree",
          "name": "Selected Code"
        },
        {
          "id": "aiProviderView",
          "name": "AI Assistant",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "experiment.showSelectedCode",
        "title": "Show Selected Code"
      },
      {
        "command": "experiment.showRoadmap",
        "title": "Show Project Roadmap"
      },
      {
        "command": "experiment.askAI",
        "title": "Ask AI About Current Code"
      }
    ],
    "keybindings": [
      {
        "command": "experiment.showSelectedCode",
        "key": "ctrl+alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "experiment.askAI",
        "key": "ctrl+alt+a",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js && node esbuild-webview.js",
    "compile:ext": "node esbuild.js",
    "compile:webview": "node esbuild-webview.js",
    "watch": "node esbuild.js --watch",
    "watch:webview": "node esbuild-webview.js --watch",
    "package": "node esbuild.js --production && node esbuild-webview.js --production",
    "lint": "eslint src",
    "build": "npm run package"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@google/generative-ai": "^0.24.1",
    "groq-sdk": "^0.37.0",
    "openai": "^6.17.0"
  }
}
